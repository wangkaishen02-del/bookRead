{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BookRead",
  "version": "1.0.0",
  "identifier": "com.wangkaishen.bookread",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BookRead",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "shortDescription": "Reading planner",
    "longDescription": "A reading planner app for managing books, milestones, and daily progress."
  }
}
